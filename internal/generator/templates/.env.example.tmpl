# ── Geral ────────────────────────────────────────────────────────────────────
APP_GENERAL_ENV=development
APP_GENERAL_TZ=UTC
APP_GENERAL_SERVICE_NAME=[[.ServiceName]]

# ── Logger ───────────────────────────────────────────────────────────────────
APP_LOGGER_LEVEL=info   # debug | info | warn | error

# ── HTTP ─────────────────────────────────────────────────────────────────────
APP_HTTP_HOST=0.0.0.0
APP_HTTP_PORT=8080
APP_HTTP_READ_TIMEOUT=15s
APP_HTTP_WRITE_TIMEOUT=15s
APP_HTTP_IDLE_TIMEOUT=60s
APP_HTTP_SHUTDOWN_TIMEOUT=30s
APP_HTTP_REQUEST_TIMEOUT=30s
APP_HTTP_MAX_BODY_SIZE=1048576

# ── TLS ──────────────────────────────────────────────────────────────────────
APP_HTTP_TLS_ENABLED=false
APP_HTTP_TLS_CERT_FILE=certs/server.crt
APP_HTTP_TLS_KEY_FILE=certs/server.key
APP_HTTP_TLS_HTTPS_ONLY=false
# APP_HTTP_TLS_REDIRECT_URL=https://localhost:8443

# ── CORS ─────────────────────────────────────────────────────────────────────
APP_HTTP_CORS_ENABLED=false
APP_HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_HTTP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_HTTP_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
APP_HTTP_CORS_MAX_AGE=300

# ── Rate Limit ────────────────────────────────────────────────────────────────
APP_HTTP_RATE_LIMIT_ENABLED=false
APP_HTTP_RATE_LIMIT_GLOBAL_LIMIT=100
APP_HTTP_RATE_LIMIT_GLOBAL_WINDOW=1m
APP_HTTP_RATE_LIMIT_GLOBAL_BURST=20

# ── CSRF ─────────────────────────────────────────────────────────────────────
APP_HTTP_CSRF_ENABLED=false
APP_HTTP_CSRF_SECRET=change-me-to-a-random-32-byte-base64-secret
APP_HTTP_CSRF_COOKIE_NAME=csrf_token
APP_HTTP_CSRF_HEADER_NAME=X-CSRF-Token
APP_HTTP_CSRF_TTL=1h

# ── Compressão ───────────────────────────────────────────────────────────────
APP_HTTP_COMPRESSION_ENABLED=true
APP_HTTP_COMPRESSION_LEVEL=5

# ── Database ─────────────────────────────────────────────────────────────────
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=[[.ServiceName]]
APP_DB_PASSWORD=secret
APP_DB_NAME=[[.ServiceName]]
APP_DB_SSLMODE=disable

# ── Redis ────────────────────────────────────────────────────────────────────
APP_REDIS_HOST=localhost
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# ── JWT ──────────────────────────────────────────────────────────────────────
APP_JWT_ACCESS_SECRET=change-me-to-a-random-32-byte-secret-for-access
APP_JWT_REFRESH_SECRET=change-me-to-a-random-32-byte-secret-for-refresh
APP_JWT_ACCESS_TOKEN_TTL=15m
APP_JWT_REFRESH_TOKEN_TTL=168h
APP_JWT_ISSUER=[[.ServiceName]]

# ── Auth ─────────────────────────────────────────────────────────────────────
APP_AUTH_MAX_LOGIN_ATTEMPTS=5
APP_AUTH_LOCKOUT_DURATION=15m

# ── Migrations ───────────────────────────────────────────────────────────────
APP_MIGRATIONS_DIR=db/migrations
