// Validate checks if the loaded configuration is valid.
func (c *Config) Validate() error {
	validEnvs := map[string]bool{
		"development": true,
		"staging":     true,
		"production":  true,
		"test":        true,
	}
	if !validEnvs[c.General.Env] {
		return fmt.Errorf("ambiente inválido: %s", c.General.Env)
	}

	validLevels := map[string]bool{"debug": true, "info": true, "warn": true, "error": true}
	if !validLevels[strings.ToLower(c.Logger.Level)] {
		return fmt.Errorf("nível de log inválido: %s", c.Logger.Level)
	}

	if c.HTTP.Port < 1 || c.HTTP.Port > 65535 {
		return fmt.Errorf("porta HTTP inválida: %d", c.HTTP.Port)
	}

	if c.HTTP.TLS.Enabled {
		if c.HTTP.TLS.CertFile == "" {
			return fmt.Errorf("cert file é obrigatório quando TLS está habilitado")
		}
		if c.HTTP.TLS.KeyFile == "" {
			return fmt.Errorf("key file é obrigatório quando TLS está habilitado")
		}
	}

	if c.Database.Credentials.Host == "" {
		return fmt.Errorf("host do banco de dados é obrigatório")
	}
	if c.Database.Credentials.Name == "" {
		return fmt.Errorf("nome do banco de dados é obrigatório")
	}
	if c.Database.Credentials.User == "" {
		return fmt.Errorf("usuário do banco de dados é obrigatório")
	}
	if c.Database.Pool.MaxOpenConns < 1 {
		return fmt.Errorf("max open connections deve ser pelo menos 1")
	}

	if c.Redis.Credentials.Host == "" {
		return fmt.Errorf("host do Redis é obrigatório")
	}
	if c.Redis.Credentials.Port < 1 || c.Redis.Credentials.Port > 65535 {
		return fmt.Errorf("porta do Redis inválida: %d", c.Redis.Credentials.Port)
	}

	if c.JWT.AccessTokenTTL <= 0 {
		return fmt.Errorf("JWT access token TTL deve ser positivo")
	}
	if c.JWT.RefreshTokenTTL <= 0 {
		return fmt.Errorf("JWT refresh token TTL deve ser positivo")
	}
	if c.JWT.Issuer == "" {
		return fmt.Errorf("JWT issuer é obrigatório")
	}

	return nil
}

// GetDatabaseDSN returns the PostgreSQL connection string.
func (c *Config) GetDatabaseDSN() string {
	return fmt.Sprintf(
		"host=%s port=%d dbname=%s user=%s password=%s sslmode=%s",
		c.Database.Credentials.Host,
		c.Database.Credentials.Port,
		c.Database.Credentials.Name,
		c.Database.Credentials.User,
		c.Database.Credentials.Password,
		c.Database.Credentials.SSLMode,
	)
}

// GetRedisAddr returns the Redis address as host:port.
func (c *Config) GetRedisAddr() string {
	return fmt.Sprintf("%s:%d", c.Redis.Credentials.Host, c.Redis.Credentials.Port)
}

// IsDevelopment returns true if the environment is development.
func (c *Config) IsDevelopment() bool {
	return c.General.Env == "development"
}

// IsProduction returns true if the environment is production.
func (c *Config) IsProduction() bool {
	return c.General.Env == "production"
}

// GetRedisRetryConfig returns retry configuration for Redis operations.
func (c *Config) GetRedisRetryConfig() *retry.Config {
	return &retry.Config{
		MaxRetries: c.Redis.Connect.BackoffRetries,
		MinBackoff: c.Redis.Connect.BackoffMin,
		MaxBackoff: c.Redis.Connect.BackoffMax,
		Factor:     float64(c.Redis.Connect.BackoffFactor),
		Jitter:     c.Redis.Connect.BackoffJitter,
	}
}

// GetDatabaseRetryConfig returns retry configuration for database operations.
func (c *Config) GetDatabaseRetryConfig() *retry.Config {
	return &retry.Config{
		MaxRetries: c.Database.Connect.BackoffRetries,
		MinBackoff: c.Database.Connect.BackoffMin,
		MaxBackoff: c.Database.Connect.BackoffMax,
		Factor:     float64(c.Database.Connect.BackoffFactor),
		Jitter:     c.Database.Connect.BackoffJitter,
	}
}

func parseCommaSeparated(s string) []string {
	if s == "" {
		return []string{}
	}
	parts := strings.Split(s, ",")
	result := make([]string, 0, len(parts))
	for _, part := range parts {
		if trimmed := strings.TrimSpace(part); trimmed != "" {
			result = append(result, trimmed)
		}
	}
	return result
}
