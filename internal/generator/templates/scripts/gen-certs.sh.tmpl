#!/usr/bin/env bash
set -euo pipefail

CERTS_DIR="certs"
mkdir -p "$CERTS_DIR"

echo "🔐 Gerando certificados TLS self-signed para desenvolvimento..."

openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
  -keyout "$CERTS_DIR/server.key" \
  -out "$CERTS_DIR/server.crt" \
  -subj "/C=BR/ST=SP/L=SaoPaulo/O=[[.ServiceName]]/CN=localhost" \
  -addext "subjectAltName=DNS:localhost,IP:127.0.0.1" 2>/dev/null

chmod 600 "$CERTS_DIR/server.key"
chmod 644 "$CERTS_DIR/server.crt"

echo "✅ Certificados gerados:"
echo "   $CERTS_DIR/server.crt"
echo "   $CERTS_DIR/server.key"
echo ""
echo "⚠️  Estes certificados são apenas para desenvolvimento. NÃO use em produção."
