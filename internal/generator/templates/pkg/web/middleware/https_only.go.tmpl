package middleware

import (
	"fmt"
	"net/http"
)

type HTTPSOnlyConfig struct {
	Enabled     bool
	RedirectURL string
}

func HTTPSOnly(cfg HTTPSOnlyConfig) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			if !cfg.Enabled {
				next.ServeHTTP(w, r)
				return
			}

			if r.TLS == nil {
				httpsURL := cfg.RedirectURL
				if httpsURL == "" {
					httpsURL = fmt.Sprintf("https://%s%s", r.Host, r.RequestURI)
				}

				w.Header().Set("Content-Type", "application/json; charset=utf-8")
				w.WriteHeader(http.StatusBadRequest)
				response := fmt.Sprintf(`{"code":"HTTPS_REQUIRED","message":"este servidor aceita apenas conexões HTTPS","https_url":"%s"}`, httpsURL)
				_, _ = w.Write([]byte(response))
				return
			}

			next.ServeHTTP(w, r)
		})
	}
}
